<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="0"
                android:endColor="@color/solo_primary"
                android:startColor="@color/solo_primary_dark" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="0"
                android:endColor="@color/solo_accent"
                android:startColor="@color/solo_primary" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
